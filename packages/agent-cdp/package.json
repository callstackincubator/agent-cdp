{
  "name": "agent-cdp",
  "version": "1.5.0",
  "description": "Command-line tool for the Chrome DevTools Protocol (CDP): debug targets, console, traces, heap snapshots, and JavaScript CPU profiling for Chrome, Node.js, and React Native.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/callstackincubator/agent-cdp.git"
  },
  "bugs": {
    "url": "https://github.com/callstackincubator/agent-cdp/issues"
  },
  "homepage": "https://github.com/callstackincubator/agent-cdp#readme",
  "license": "MIT",
  "bin": {
    "agent-cdp": "./dist/bin.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsup",
    "format": "oxfmt --write \"src/**/*.ts\" package.json tsconfig.json tsup.config.ts vitest.config.ts",
    "format:check": "oxfmt --check \"src/**/*.ts\" package.json tsconfig.json tsup.config.ts vitest.config.ts",
    "lint": "oxlint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-cdp/protocol": "workspace:*",
    "@jridgewell/trace-mapping": "^0.3.31",
    "commander": "^14.0.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "oxfmt": "^0.17.0",
    "oxlint": "^0.17.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
